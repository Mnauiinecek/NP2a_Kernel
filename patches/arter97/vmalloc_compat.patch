diff --git a/mm/vmalloc.c b/mm/vmalloc.c
index 3d2e0a7c2..2f8e3d7d4 100644
--- a/mm/vmalloc.c
+++ b/mm/vmalloc.c
@@ -333,7 +333,11 @@ static void vunmap_pte_range(pmd_t *pmd, unsigned long addr, unsigned long end,
 		if (size != PAGE_SIZE) {
 			if (WARN_ON(!IS_ALIGNED(addr, size))) {
 				addr = ALIGN_DOWN(addr, size);
 				pte = PTR_ALIGN_DOWN(pte, sizeof(*pte) * (size >> PAGE_SHIFT));
 			}
-			ptent = huge_ptep_get_and_clear(&init_mm, addr, pte, size);
+#ifdef CONFIG_ARM64
+			ptent = huge_ptep_get_and_clear(&init_mm, addr, pte);
+#else
+			ptent = huge_ptep_get_and_clear(&init_mm, addr, pte, size);
+#endif
 			if (WARN_ON(end - addr < size))
 				size = end - addr;
 		} else
@@ -634,6 +638,13 @@ static int vmap_pages_range(unsigned long addr, unsigned long end,
 	flush_cache_vmap(addr, end);
 	return err;
 }
+
+int map_kernel_range(unsigned long addr, unsigned long size, pgprot_t prot,
+			     struct page **pages)
+{
+	return vmap_pages_range(addr, addr + size, prot, pages, PAGE_SHIFT);
+}
 EXPORT_SYMBOL_GPL(map_kernel_range);
